MODE=development
HTTP_PORT=8888

# Which workflow to run:
#   api      -> WhatsMeow, unofficial personal account, logs in via QR code
#   business -> Meta WhatsApp Business Cloud API, uses an access token
WHATSAPP_PROVIDER=api

# --- api workflow (WhatsMeow) ---
# The WhatsMeow session store runs on PostgreSQL (required for the api provider).
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASS=
DB_NAME=my_whatsapp
# Schema holding the whatsmeow_* tables. Leave empty to use the default (public).
DB_SCHEMA=whatsmeow

# --- business workflow (Meta WhatsApp Business Cloud API) ---
WHATSAPP_BUSINESS_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCESS_TOKEN=
WHATSAPP_BUSINESS_API_VERSION=v21.0

# Webhook verification token for the Business Cloud API GET handshake
WHATSAPP_API_WEBHOOK_VERIFY_TOKEN=change-me

# --- Google Cloud Pub/Sub (internal/pubsub demo) ---
# Full service-account key JSON, squashed onto ONE line. Generate with:
#   gcloud iam service-accounts keys create key.json --iam-account=SA@PROJECT.iam.gserviceaccount.com
#   jq -c . key.json    # then paste the single-line output below
GCP_SA_KEY={"type":"service_account","project_id":"...","private_key":"..."}
